# ROS Distribution. Available variables:
DOCKER_ROS_DISTRO=jazzy

# Type of installation. Available variables:
# BASE_IMAGE=hardware
BASE_IMAGE=gazebo
# BASE_IMAGE=gazebo-cuda

# Robot type. Available variables: 2wd 4wd mecanum
ROBOT_BASE=2wd

# 2D laser scanner to be used. Available variables: ldlidar rplidar ydlidar xv11
LASER_SENSOR=

# Depth sensor to be used. Available variables: realsense zed zedm zed2 zed2i
DEPTH_SENSOR=

# Base Serial Port
BASE_SERIAL_PORT=/dev/ttyACM0

# Odometry topic
ODOM_TOPIC=/odom

# Default ROS_DOMAIN_ID
ROS_DOMAIN_ID=0

# Launch custom robot launch file. DO NOT SET THIS unless you're using a custom launch file.
CUSTOM_ROBOT=false

# Launch extra launch file
LAUNCH_EXTRA=false

# Launch Joystick
LAUNCH_JOYSTICK=false

# GPU ID to use
GPU_ID=0

# Set VirtualGL version
VIRTUALGL_VER=3.1.4
