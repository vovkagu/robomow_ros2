<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="base_length" value="0.60" /> <xacro:property name="base_width" value="0.45" />  <xacro:property name="base_height" value="0.10" /> 
  <xacro:property name="base_mass" value="10" />     <xacro:property name="base_mesh_file" value="" />

  <xacro:property name="wheel_radius" value="0.10795" />
