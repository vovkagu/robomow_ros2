  <xacro:property name="wheel_pos_y" value="0.2794" /> <xacro:property name="wheel_pos_z" value="-0.10795" />
  <xacro:property name="wheel_mass" value="1.0" />
  <xacro:property name="wheel_torque" value="20" />

  <xacro:property name="front_caster_wheel" value="true" />
  <xacro:property name="rear_caster_wheel" value="false" />
  <xacro:property name="caster_wheel_radius" value="0.04445" /> 
  <xacro:property name="caster_wheel_pos_x" value="0.4826" />   
